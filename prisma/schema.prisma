generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Employee {
  id             String   @id @default(cuid())
  employeeId     String?  @unique
  fullName       String
  title          String
  authorizations String
  licenses       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model User {
  id       String @id @default(cuid())
  username String @unique
  password String
}
